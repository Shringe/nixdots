[
  {
    "output": [ "DP-3", "eDP-1" ],
    "battery": {
      "bat": "BAT0",
      "format": "{capacity}% {icon}",
      "format-icons": [
        "ΎΚΕ",
        "ΎΚΔ",
        "ΎΚΓ",
        "ΎΚΒ",
        "ΎΚΑ"
      ],
      "states": {
        "critical": 15,
        "warning": 30
      }
    },
    "cava": {
      "autosens": 1,
      "bar_delimiter": 0,
      "bars": 12,
      "format-icons": [
        "έΨΒ",
        "έΨΓ",
        "έΨΔ",
        "έΨΕ",
        "έΨΖ",
        "έΨΗ",
        "έΨΘ",
        "έΨΙ"
      ],
      "framerate": 30,
      "hide_on_silence": true,
      "method": "pipewire",
      "reverse": false,
      "source": "auto",
      "stereo": true
    },
    "clock": {
      "format": "{:%a %d %b ΎΕ│ %I:%M %p} ΎΑΩ"
    },
    "cpu": {
      "format": "{usage}% ΎΜδ"
    },
    "custom/leftSeparator1": {
      "format": "/",
      "tooltip": false
    },
    "custom/leftSeparator2": {
      "format": "/",
      "tooltip": false
    },
    "custom/midSeparator1": {
      "format": "ΎΕΑ",
      "tooltip": false
    },
    "custom/midSeparator2": {
      "format": "ΎΕΒ",
      "tooltip": false
    },
    "custom/nordvpn": {
      "exec": "nordstatus",
      "format": "VPN: {}",
      "interval": 5,
      "on-click": "nordvpn connect",
      "on-click-right": "nordvpn disconnect"
    },
    "custom/notification": {
      "escape": true,
      "exec": "swaync-client -swb",
      "exec-if": "which swaync-client",
      "format": "{} {icon}",
      "format-icons": {
        "dnd-inhibited-none": "ΎΘ╖",
        "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
        "dnd-none": "ΎΘ╖",
        "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
        "inhibited-none": "ΎΓλ",
        "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
        "none": "ΎΓλ",
        "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>"
      },
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "on-click-middle": "swaync-client -C -sw",
      "return-type": "json"
    },
    "custom/rightSeparator1": {
      "format": "\\",
      "tooltip": false
    },
    "custom/rightSeparator2": {
      "format": "\\",
      "tooltip": false
    },
    "custom/rightSeparator3": {
      "format": "\\",
      "tooltip": false
    },
    "custom/rightSeparator4": {
      "format": "\\",
      "tooltip": false
    },
    "custom/rightSeparator5": {
      "format": "\\",
      "tooltip": false
    },
    "niri/workspaces": {
      "all-outputs": true,
      "format": "{icon}",
      "format-icons": {
        "1":  "ΎΝΥ",
        "2":  "≤░Ι╣",
        "3":  "ΎΞψ",
        "4":  "≤░ψβ",
        "5":  "≤░ΦΞ",
        "6":  "≤░ΥΥ",
        "7":  "≤░ΟΗ",
        "8":  "ΎΒ╡",
        "9":  "≤░Θχ",
        "10": "≤░ΞΦ"
      }
    },
    "niri/window": {
      "icon": false,
      "icon-size": 10
    },
    "height": 24,
    "layer": "top",
    "memory": {
      "format": "{}% ΎΔΚ"
    },
    "modules-center": [
      "custom/midSeparator1",
      "niri/workspaces",
      "custom/midSeparator2"
    ],
    "modules-left": [
      "tray",
      "privacy",
      "custom/leftSeparator1",
      "niri/window",
      "custom/leftSeparator2"
    ],
    "modules-right": [
      "custom/rightSeparator4",
      "mpris",
      "cava",
      "pulseaudio",
      "custom/rightSeparator2",
      "battery",
      "memory",
      "cpu",
      "custom/rightSeparator1",
      "custom/notification",
      "clock"
    ],
    "mpris": {
      "format": "{title}",
      "status-icons": {
        "paused": "έΠ╕",
        "playing": "έΨ╢"
      }
    },
    "network": {
      "format-disconnected": "Disconnected έγι",
      "format-ethernet": "{ifname}: {ipaddr}/{cidr} ΎΔΒ",
      "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
      "on-click": "toggleProcess iwgtk",
      "on-click-right": "notifyCopy 'Public IP' $(curl icanhazip.com)"
    },
    "position": "top",
    "privacy": {
      "modules": [
        {
          "type": "screenshare"
        }
      ]
    },
    "pulseaudio": {
      "format": "{volume}% {icon}",
      "format-bluetooth": "{volume}% {icon}ΎΛΦ",
      "format-icons": {
        "car": "ΎΗ╣",
        "default": [
          "ΎΑπ",
          "ΎΑρ"
        ],
        "handsfree": "ΎΨΡ",
        "headphones": "ΎΑξ",
        "headset": "ΎΨΡ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ"
      },
      "format-muted": "{volume}% ΏθΦΘ",
      "on-click": "pavucontrol-qt",
      "on-click-right": "wpctl set-mute @DEFAULT_SINK@ toggle"
    },
    "tray": {
      "spacing": 5
    }
  },
